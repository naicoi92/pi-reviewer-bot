# ─────────────────────────────────────────────────────────────
# pi-reviewer-bot — env vars
# Copy file này thành `.env` (KHÔNG commit .env)
#
# Bot dùng Pi Coding Agent SDK → hỗ trợ 40+ LLM providers.
# Set API key của provider bạn muốn dùng (có thể set nhiều cùng lúc).
# Xem full list: https://pi.dev/models hoặc chạy `pi --list-models`
# ─────────────────────────────────────────────────────────────

# ═══ BẮT BUỘC ═══

# Secret để verify webhook từ GitLab (X-Gitlab-Token header).
# Generate: openssl rand -hex 16
# PHẢI khớp với "Secret token" set trong GitLab project webhook.
WEBHOOK_SECRET=

# GitLab Personal/Project Access Token cho bot account.
# Scope: `api`. Role: Developer trở lên trên mỗi project muốn review.
GITLAB_API_TOKEN=

# ═══ LLM PROVIDER (chọn 1 hoặc nhiều — Pi auto-detect) ═══

# Z.ai Coding Plan (default recommend, $12.6/mo flat, glm-5.2 1M context)
# Lấy key: https://z.ai/console
ZAI_API_KEY=

# OpenAI (GPT-4o, o1, ...) — pay-as-you-go
# OPENAI_API_KEY=

# Anthropic (Claude 3.5 Sonnet, Opus, ...) — pay-as-you-go
# ANTHROPIC_API_KEY=

# DeepSeek (chat, coder) — rẻ nhất, pay-as-you-go
# DEEPSEEK_API_KEY=

# Google Gemini
# GOOGLE_GENERATIVE_AI_API_KEY=

# AWS Bedrock / Vertex AI / Azure OpenAI / Mistral / Cohere / Ollama local ...
# Xem docs Pi cho env var từng provider: https://pi.dev/docs/latest/providers

# ═══ MODEL SELECTION ═══

# Default model (Format: "provider/model"). Bỏ trống → Pi auto-pick.
# Examples:
#   DEFAULT_MODEL=zai/glm-5.2          # Z.ai GLM-5.2 (recommend)
#   DEFAULT_MODEL=openai/gpt-4o        # OpenAI GPT-4o
#   DEFAULT_MODEL=anthropic/claude-3-5-sonnet-latest
#   DEFAULT_MODEL=deepseek/deepseek-chat
#   DEFAULT_MODEL=                     # empty → Pi auto-detect from auth
DEFAULT_MODEL=zai/glm-5.2

# ═══ NETWORK ═══

PORT=3000
GITLAB_URL=https://gitlab.com

# ═══ REVIEW BEHAVIOR ═══

# Timeout mỗi review (ms)
REVIEW_TIMEOUT_MS=300000

# Multi-project tuning
MAX_CONCURRENT_REVIEWS=3
PER_PROJECT_COOLDOWN_MS=10000
MAX_TOOL_CALLS_PER_REVIEW=30

# ═══ SECURITY ═══

# Bearer token bảo vệ /stats endpoint (bỏ trống = public)
STATS_AUTH_TOKEN=

NODE_ENV=production

# ═══ PATHS (thường không cần đổi) ═══

REPO_TMP_ROOT=/tmp/pi-reviews
PI_AGENT_DIR=/tmp/pi-agent
LOG_LEVEL=info
