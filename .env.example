# ─────────────────────────────────────────────────────────────
# pi-reviewer-bot — env vars
# Copy file này thành `.env` (KHÔNG commit .env)
#
# Khi chạy Docker: docker compose up tự đọc .env ở root.
# Khi chạy Kubernetes: convert thành Secret + mount as env.
# Khi chạy systemd: set trong /etc/systemd/system/pi-reviewer-bot.service.
# ─────────────────────────────────────────────────────────────

# ═══ BẮT BUỘC ═══

# Secret để verify webhook từ GitLab (X-Gitlab-Token header).
# Generate: openssl rand -hex 16
# PHẢI khớp với "Secret token" set trong GitLab project webhook.
WEBHOOK_SECRET=

# GitLab Personal/Project Access Token cho bot account.
# Scope: `api`. Role: Developer trở lên trên mỗi project muốn review.
GITLAB_API_TOKEN=

# Z.ai Coding Plan API key (Pi auto-detects provider "zai" từ env này)
# Lấy tại: https://z.ai/console
ZAI_API_KEY=

# ═══ NETWORK ═══

# Port暴露 ra ngoài (match với docker-compose ports)
PORT=3000

# GitLab host (mặc định gitlab.com; đổi nếu self-managed)
GITLAB_URL=https://gitlab.com

# ═══ MODEL ═══

# Default model (Pi Coding Agent syntax: provider/model)
# Z.ai Coding Plan — provider "zai" native, chỉ cần ZAI_API_KEY
DEFAULT_MODEL=zai/glm-5.2

# Timeout mỗi review (ms) — kill process nếu vượt
REVIEW_TIMEOUT_MS=300000

# ═══ MULTI-PROJECT TUNING ═══

# Số review chạy song song global (mỗi review ~200MB RAM)
# 512MB container → 2-3 an toàn; 1GB container → 5-7
MAX_CONCURRENT_REVIEWS=3

# Cooldown giữa các review cùng project (ms) — chống infinite loop
PER_PROJECT_COOLDOWN_MS=10000

# Cap tool calls mỗi review (chống AI spam)
MAX_TOOL_CALLS_PER_REVIEW=30

# ═══ SECURITY ═══

# Bearer token bảo vệ /stats endpoint (bỏ trống = public)
STATS_AUTH_TOKEN=

# Production flag — khi true, bắt buộc verify WEBHOOK_SECRET
NODE_ENV=production

# ═══ PATHS (thường không cần đổi) ═══

# Root dir cho clone workspace
REPO_TMP_ROOT=/tmp/pi-reviews

# Pi agent cache dir (settings/auth)
PI_AGENT_DIR=/tmp/pi-agent

# Log level (debug/info/warn/error)
LOG_LEVEL=info
